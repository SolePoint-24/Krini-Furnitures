{% doc %}
  @prompt
    i want to create section as per following options:
    6 column
    each column include :
    Icon
    Number
    Heading
    description
    image
    
    this section represents process, steps - 01, 02, 03 like this  
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-process-steps-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-process-steps__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-process-steps__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-process-steps__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
  }

  .ai-process-steps__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-process-steps__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.column_gap }}px;
    margin-top: {{ block.settings.grid_spacing }}px;
  }

  .ai-process-step-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: {{ block.settings.step_padding }}px;
    background-color: {{ block.settings.step_background }};
    border-radius: {{ block.settings.step_border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-process-step-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-process-step__icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background }};
    border-radius: 50%;
    flex-shrink: 0;
  }

  .ai-process-step__icon-wrapper-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    fill: {{ block.settings.icon_color }};
  }

  .ai-process-step__number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    color: {{ block.settings.number_color }};
    margin-bottom: 12px;
  }

  .ai-process-step__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-process-step__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 16px;
    line-height: 1.5;
  }

  .ai-process-step__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-top: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-process-step__image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-process-step__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-process-step__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 989px) {
    .ai-process-steps__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-process-steps__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-process-steps__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .ai-process-steps__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }

    .ai-process-step__icon-wrapper-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.8);
      height: calc({{ block.settings.icon_size }}px * 0.8);
    }

    .ai-process-step__icon-wrapper-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.icon_size }}px * 0.4);
      height: calc({{ block.settings.icon_size }}px * 0.4);
    }
  }
{% endstyle %}

<process-steps-{{ ai_gen_id }} class="ai-process-steps-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-process-steps__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-process-steps__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-process-steps__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-process-steps__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-process-steps__grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign step_heading_key = 'step_' | append: i | append: '_heading'
          assign step_description_key = 'step_' | append: i | append: '_description'
          assign step_image_key = 'step_' | append: i | append: '_image'
          
          assign step_heading = block.settings[step_heading_key]
          assign step_description = block.settings[step_description_key]
          assign step_image = block.settings[step_image_key]
        %}

        <div class="ai-process-step-{{ ai_gen_id }}">
          <div class="ai-process-step__icon-wrapper-{{ ai_gen_id }}">
            {% case i %}
              {% when 1 %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V7.89l7-3.11v8.2z"/>
                </svg>
              {% when 2 %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                </svg>
              {% when 3 %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
              {% when 4 %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20 6h-2.18c.11-.31.18-.65.18-1 0-1.66-1.34-3-3-3-1.05 0-1.96.54-2.5 1.35l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h5.08L7 10.83 8.62 12 11 8.76l1-1.36 1 1.36L15.38 12 17 10.83 14.92 8H20v6z"/>
                </svg>
              {% when 5 %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
              {% when 6 %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/>
                </svg>
            {% endcase %}
          </div>

          <div class="ai-process-step__number-{{ ai_gen_id }}">
            {% if i < 10 %}0{% endif %}{{ i }}
          </div>

          {% if step_heading != blank %}
            <h3 class="ai-process-step__heading-{{ ai_gen_id }}">{{ step_heading }}</h3>
          {% else %}
            <h3 class="ai-process-step__heading-{{ ai_gen_id }}">Step {{ i }}</h3>
          {% endif %}

          {% if step_description != blank %}
            <div class="ai-process-step__description-{{ ai_gen_id }}">{{ step_description }}</div>
          {% else %}
            <div class="ai-process-step__description-{{ ai_gen_id }}">Add a description for step {{ i }}</div>
          {% endif %}

          <div class="ai-process-step__image-wrapper-{{ ai_gen_id }}">
            {% if step_image %}
              <img
                src="{{ step_image | image_url: width: 400 }}"
                alt="{{ step_image.alt | escape }}"
                loading="lazy"
                width="{{ step_image.width }}"
                height="{{ step_image.height }}"
              >
            {% else %}
              <div class="ai-process-step__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</process-steps-{{ ai_gen_id }}>

<script>
  (function() {
    class ProcessSteps{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('process-steps-{{ ai_gen_id }}', ProcessSteps{{ ai_gen_id }});
  })();
</script>

